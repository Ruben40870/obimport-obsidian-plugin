  "author": "Ruben Triegaardt",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.21.5",
    "obsidian": "1.5.7",
    "tslib": "2.6.3",
    "typescript": "5.4.5"
  }
}
